/// Converts Markdown to HTML (CommonMark 0.31.2 core).
/// Supported (pragmatic subset): fenced code blocks (```), ATX headings (#..######),
/// unordered lists (-, *, +), paragraphs, blank-line separation, and basic inline
/// formatting: code spans (`code`), strong (**bold**), emphasis (*italic*).
///
/// Notes / limitations:
/// - This is not a complete CommonMark implementation (no blockquotes, tables, setext headings,
///   tight/loose list nuance, link reference definitions, nested lists, thematic breaks, etc.).
/// - Inline parsing is intentionally simple and may not match all edge cases from the spec.
/// - Partial link paths are not supported ([link](/res/img.png))
function 'Fi.Convert.MDtoHTML' = ```
		(
		    // Markdown input
		    markdown: STRING
		) =>
		VAR LF = UNICHAR( 10 )
		VAR CR = UNICHAR( 13 )
		VAR __Text0 =
		    // Normalize line breaks to LF
		    SUBSTITUTE( SUBSTITUTE( markdown, CR & LF, LF ), CR, LF )

		// Pragmatic: flatten blockquote-wrapped lines (`> `) since blockquotes
		// are not fully implemented; this also allows inline constructs (like links)
		// to span across wrapped `> ` lines.
		VAR __Text1 = SUBSTITUTE( __Text0, LF & "> ", " " )

		// Split into lines using PATH* (| delimiter)
		VAR __Path = SUBSTITUTE( __Text1, LF, "|" )
		VAR __LineCount =
		    VAR n = PATHLENGTH( __Path )
		    RETURN IF( __Text1 = BLANK(), 0, n )

		VAR __Lines =
		    ADDCOLUMNS(
		        GENERATESERIES( 1, __LineCount, 1 ),
		        "LineRaw",
		            VAR __L0 = PATHITEM( __Path, [Value], TEXT )
		            VAR __T = TRIM( __L0 )
		            RETURN IF( LEFT( __T, 2 ) = "> ", MID( __T, 3, LEN( __T ) - 2 ), __L0 )
		    )

		VAR __Lines2 =
		    ADDCOLUMNS(
		        __Lines,
		        "LineTrim", TRIM( [LineRaw] ),
		        "IsBlank", LEN( TRIM( [LineRaw] ) ) = 0,
		        "IsFence", LEFT( TRIM( [LineRaw] ), 3 ) = "```",
		        "IsUL",
		            VAR t = TRIM( [LineRaw] )
		            RETURN
		                ( LEFT( t, 2 ) = "- " )
		                    || ( LEFT( t, 2 ) = "* " )
		                    || ( LEFT( t, 2 ) = "+ " ),
		        "HeadingLevel",
		            VAR t = [LineRaw]
		            RETURN
		                SWITCH(
		                    TRUE(),
		                    LEFT( t, 7 ) = "###### ", 6,
		                    LEFT( t, 6 ) = "##### ",  5,
		                    LEFT( t, 5 ) = "#### ",   4,
		                    LEFT( t, 4 ) = "### ",    3,
		                    LEFT( t, 3 ) = "## ",     2,
		                    LEFT( t, 2 ) = "# ",      1,
		                    0
		                ),
		        "FenceCountBefore",
		            VAR i = [Value]
		            RETURN
		                SUMX(
		                    FILTER( __Lines, [Value] < i ),
		                    VAR t2 = TRIM( [LineRaw] )
		                    RETURN IF( LEFT( t2, 3 ) = "```", 1, 0 )
		                )
		    )

		VAR __Lines3 =
		    ADDCOLUMNS(
		        __Lines2,
		        "InCodeBefore", MOD( [FenceCountBefore], 2 ) = 1,
		        "IsFenceStart", ( MOD( [FenceCountBefore], 2 ) = 0 ) && [IsFence],
		        "IsFenceEnd",   ( MOD( [FenceCountBefore], 2 ) = 1 ) && [IsFence]
		    )

		// Build HTML by rendering each line with boundary-aware wrappers.
		VAR __Html =
		    CONCATENATEX(
		        __Lines3,
		        VAR __I = [Value]
		        VAR __LineRaw = [LineRaw]
		        VAR __LineTrim = [LineTrim]

		        VAR __PrevIsUL =
		            VAR __P = __I - 1
		            RETURN
		                IF(
		                    __P < 1,
		                    FALSE(),
		                    MAXX( FILTER( __Lines3, [Value] = __P ), IF( [IsUL], 1, 0 ) ) = 1
		                )
		        VAR __NextIsUL =
		            VAR __N = __I + 1
		            RETURN
		                IF(
		                    __N > __LineCount,
		                    FALSE(),
		                    MAXX( FILTER( __Lines3, [Value] = __N ), IF( [IsUL], 1, 0 ) ) = 1
		                )

		        VAR __PrevIsParaLine =
		            VAR __P = __I - 1
		            RETURN
		                IF(
		                    __P < 1,
		                    FALSE(),
		                    MAXX(
		                        FILTER( __Lines3, [Value] = __P ),
		                        IF(
		                            NOT [IsBlank]
		                                && NOT [IsUL]
		                                && [HeadingLevel] = 0
		                                && NOT [IsFence]
		                                && NOT [InCodeBefore],
		                            1,
		                            0
		                        )
		                    )
		                        = 1
		                )
		        VAR __NextIsParaLine =
		            VAR __N = __I + 1
		            RETURN
		                IF(
		                    __N > __LineCount,
		                    FALSE(),
		                    MAXX(
		                        FILTER( __Lines3, [Value] = __N ),
		                        IF(
		                            NOT [IsBlank]
		                                && NOT [IsUL]
		                                && [HeadingLevel] = 0
		                                && NOT [IsFence]
		                                && NOT [InCodeBefore],
		                            1,
		                            0
		                        )
		                    )
		                        = 1
		                )

		        // HTML escaping (basic)
		        VAR __Pch = UNICHAR( 57344 )
		        VAR __Esc0 =
		            VAR __T1 = SUBSTITUTE( __LineRaw, "&", __Pch )
		            VAR __T2 = SUBSTITUTE( __T1, "<", "&lt;" )
		            VAR __T3 = SUBSTITUTE( __T2, ">", "&gt;" )
		            VAR __T4 = SUBSTITUTE( __T3, """", "&quot;" )
		            RETURN SUBSTITUTE( __T4, __Pch, "&amp;" )

		        // Inline: code spans using backticks (simple, single-line)
		        // PATH* only splits on '|', so we temporarily shield existing '|' characters.
		        VAR __InlineCode =
		            VAR __Shield = UNICHAR( 57345 )
		            VAR __Safe = SUBSTITUTE( __Esc0, "|", __Shield )
		            VAR __Pth = SUBSTITUTE( __Safe, "`", "|" )
		            VAR __Parts = PATHLENGTH( __Pth )
		            RETURN
		                IF(
		                    __Parts = 1,
		                    __Esc0,
		                    CONCATENATEX(
		                        GENERATESERIES( 1, __Parts, 1 ),
		                        VAR __K = [Value]
		                        VAR __Seg0 = PATHITEM( __Pth, __K, TEXT )
		                        VAR __Seg = SUBSTITUTE( __Seg0, __Shield, "|" )
		                        RETURN IF( MOD( __K, 2 ) = 0, "<code>" & __Seg & "</code>", __Seg ),
		                        "",
		                        [Value],
		                        ASC
		                    )
		                )

		        // Inline: links [text](href) outside <code> spans (pragmatic)
		        VAR __InlineLinks =
		            VAR __PosCodeOpen = SEARCH( "<code>", __InlineCode, 1, 0 )
		            RETURN
		                IF(
		                    __PosCodeOpen = 0,
		                    // No code span: linkify whole line once
		                    VAR __S = __InlineCode
		                    VAR __PosOpen = SEARCH( "[", __S, 1, 0 )
		                    VAR __PosMid = IF( __PosOpen = 0, 0, SEARCH( "](", __S, __PosOpen + 1, 0 ) )
		                    VAR __PosClose = IF( __PosMid = 0, 0, SEARCH( ")", __S, __PosMid + 2, 0 ) )
		                    RETURN
		                        IF(
		                            __PosOpen = 0 || __PosMid = 0 || __PosClose = 0,
		                            __S,
		                            VAR __Before = LEFT( __S, __PosOpen - 1 )
		                            VAR __Txt = MID( __S, __PosOpen + 1, __PosMid - __PosOpen - 1 )
		                            VAR __Href = MID( __S, __PosMid + 2, __PosClose - __PosMid - 2 )
		                            VAR __After = MID( __S, __PosClose + 1, LEN( __S ) - __PosClose )
		                            RETURN __Before & "<a href=""" & __Href & """>" & __Txt & "</a>" & __After
		                        ),
		                    // Has a code span: linkify before and after the first code span
		                    VAR __Before0 = LEFT( __InlineCode, __PosCodeOpen - 1 )
		                    VAR __Rest0 = MID( __InlineCode, __PosCodeOpen + 6, LEN( __InlineCode ) - ( __PosCodeOpen + 5 ) )
		                    VAR __PosCodeClose = SEARCH( "</code>", __Rest0, 1, 0 )
		                    RETURN
		                        IF(
		                            __PosCodeClose = 0,
		                            VAR __S = __Before0
		                            VAR __PosOpen = SEARCH( "[", __S, 1, 0 )
		                            VAR __PosMid = IF( __PosOpen = 0, 0, SEARCH( "](", __S, __PosOpen + 1, 0 ) )
		                            VAR __PosClose = IF( __PosMid = 0, 0, SEARCH( ")", __S, __PosMid + 2, 0 ) )
		                            VAR __Before1 =
		                                IF(
		                                    __PosOpen = 0 || __PosMid = 0 || __PosClose = 0,
		                                    __S,
		                                    VAR __Before = LEFT( __S, __PosOpen - 1 )
		                                    VAR __Txt = MID( __S, __PosOpen + 1, __PosMid - __PosOpen - 1 )
		                                    VAR __Href = MID( __S, __PosMid + 2, __PosClose - __PosMid - 2 )
		                                    VAR __After = MID( __S, __PosClose + 1, LEN( __S ) - __PosClose )
		                                    RETURN __Before & "<a href=""" & __Href & """>" & __Txt & "</a>" & __After
		                                )
		                            RETURN __Before1 & "<code>" & __Rest0,
		                            VAR __CodeInside = LEFT( __Rest0, __PosCodeClose - 1 )
		                            VAR __After0 = MID( __Rest0, __PosCodeClose + 7, LEN( __Rest0 ) - ( __PosCodeClose + 6 ) )
		                            VAR __S = __Before0
		                            VAR __PosOpen = SEARCH( "[", __S, 1, 0 )
		                            VAR __PosMid = IF( __PosOpen = 0, 0, SEARCH( "](", __S, __PosOpen + 1, 0 ) )
		                            VAR __PosClose = IF( __PosMid = 0, 0, SEARCH( ")", __S, __PosMid + 2, 0 ) )
		                            VAR __Before1 =
		                                IF(
		                                    __PosOpen = 0 || __PosMid = 0 || __PosClose = 0,
		                                    __S,
		                                    VAR __Before = LEFT( __S, __PosOpen - 1 )
		                                    VAR __Txt = MID( __S, __PosOpen + 1, __PosMid - __PosOpen - 1 )
		                                    VAR __Href = MID( __S, __PosMid + 2, __PosClose - __PosMid - 2 )
		                                    VAR __After = MID( __S, __PosClose + 1, LEN( __S ) - __PosClose )
		                                    RETURN __Before & "<a href=""" & __Href & """>" & __Txt & "</a>" & __After
		                                )
		                            VAR __S2 = __After0
		                            VAR __PosOpen2 = SEARCH( "[", __S2, 1, 0 )
		                            VAR __PosMid2 = IF( __PosOpen2 = 0, 0, SEARCH( "](", __S2, __PosOpen2 + 1, 0 ) )
		                            VAR __PosClose2 = IF( __PosMid2 = 0, 0, SEARCH( ")", __S2, __PosMid2 + 2, 0 ) )
		                            VAR __After1 =
		                                IF(
		                                    __PosOpen2 = 0 || __PosMid2 = 0 || __PosClose2 = 0,
		                                    __S2,
		                                    VAR __Before = LEFT( __S2, __PosOpen2 - 1 )
		                                    VAR __Txt = MID( __S2, __PosOpen2 + 1, __PosMid2 - __PosOpen2 - 1 )
		                                    VAR __Href = MID( __S2, __PosMid2 + 2, __PosClose2 - __PosMid2 - 2 )
		                                    VAR __After = MID( __S2, __PosClose2 + 1, LEN( __S2 ) - __PosClose2 )
		                                    RETURN __Before & "<a href=""" & __Href & """>" & __Txt & "</a>" & __After
		                                )
		                            RETURN __Before1 & "<code>" & __CodeInside & "</code>" & __After1
		                        )
		                )

		        // Inline: strong (** .. **) and emphasis (* .. *) outside code blocks (simple toggles)
		        VAR __InlineStrong =
		            VAR __Shield = UNICHAR( 57345 )
		            VAR __Safe = SUBSTITUTE( __InlineLinks, "|", __Shield )
		            VAR __Pth = SUBSTITUTE( __Safe, "**", "|" )
		            VAR __Parts = PATHLENGTH( __Pth )
		            VAR __Ok = MOD( __Parts - 1, 2 ) = 0
		            RETURN
		                IF(
		                    NOT __Ok,
		                    __InlineLinks,
		                    CONCATENATEX(
		                        GENERATESERIES( 1, __Parts, 1 ),
		                        VAR __K = [Value]
		                        VAR __Seg0 = PATHITEM( __Pth, __K, TEXT )
		                        VAR __Seg = SUBSTITUTE( __Seg0, __Shield, "|" )
		                        RETURN IF( MOD( __K, 2 ) = 0, "<strong>" & __Seg & "</strong>", __Seg ),
		                        "",
		                        [Value],
		                        ASC
		                    )
		                )

		        VAR __InlineEm =
		            VAR __Shield = UNICHAR( 57345 )
		            VAR __Safe = SUBSTITUTE( __InlineStrong, "|", __Shield )
		            VAR __Pth = SUBSTITUTE( __Safe, "*", "|" )
		            VAR __Parts = PATHLENGTH( __Pth )
		            VAR __Ok = MOD( __Parts - 1, 2 ) = 0
		            RETURN
		                IF(
		                    NOT __Ok,
		                    __InlineStrong,
		                    CONCATENATEX(
		                        GENERATESERIES( 1, __Parts, 1 ),
		                        VAR __K = [Value]
		                        VAR __Seg0 = PATHITEM( __Pth, __K, TEXT )
		                        VAR __Seg = SUBSTITUTE( __Seg0, __Shield, "|" )
		                        RETURN IF( MOD( __K, 2 ) = 0, "<em>" & __Seg & "</em>", __Seg ),
		                        "",
		                        [Value],
		                        ASC
		                    )
		                )

		        VAR __RenderedInline = __InlineEm

		        VAR __OpenUL = IF( [IsUL] && NOT __PrevIsUL && NOT [InCodeBefore], "<ul>" & LF, "" )
		        VAR __CloseUL = IF( [IsUL] && NOT __NextIsUL && NOT [InCodeBefore], LF & "</ul>" & LF, "" )

		        VAR __OpenP =
		            IF(
		                NOT [InCodeBefore]
		                    && NOT [IsFence]
		                    && NOT [IsBlank]
		                    && NOT [IsUL]
		                    && [HeadingLevel] = 0
		                    && NOT __PrevIsParaLine,
		                "<p>",
		                ""
		            )
		        VAR __CloseP =
		            IF(
		                NOT [InCodeBefore]
		                    && NOT [IsFence]
		                    && NOT [IsBlank]
		                    && NOT [IsUL]
		                    && [HeadingLevel] = 0
		                    && NOT __NextIsParaLine,
		                "</p>" & LF,
		                ""
		            )

		        VAR __Li =
		            IF(
		                [IsUL] && NOT [InCodeBefore],
		                VAR __T = __LineTrim
		                VAR __Content = MID( __T, 3, LEN( __T ) - 2 )
		                RETURN "<li>" & __Content & "</li>",
		                BLANK()
		            )

		        VAR __Heading =
		            IF(
		                NOT [InCodeBefore] && [HeadingLevel] > 0,
		                VAR __Lvl = [HeadingLevel]
		                VAR __Content = MID( __LineRaw, __Lvl + 2, LEN( __LineRaw ) - ( __Lvl + 1 ) )
		                VAR __Slug0 = LOWER( TRIM( __Content ) )
		                VAR __Slug1 =
		                    SUBSTITUTE(
		                        SUBSTITUTE(
		                            SUBSTITUTE(
		                                SUBSTITUTE(
		                                    SUBSTITUTE(
		                                        SUBSTITUTE(
		                                            SUBSTITUTE(
		                                                SUBSTITUTE(
		                                                    SUBSTITUTE(
		                                                        SUBSTITUTE(
		                                                            SUBSTITUTE(
		                                                                SUBSTITUTE( __Slug0, ".", "" ),
		                                                                ",", ""
		                                                            ),
		                                                            ":", ""
		                                                        ),
		                                                        ";", ""
		                                                    ),
		                                                    "!", ""
		                                                ),
		                                                "?", ""
		                                            ),
		                                            """", ""
		                                        ),
		                                        "'", ""
		                                    ),
		                                    "(", ""
		                                ),
		                                ")", ""
		                            ),
		                            "[", ""
		                        ),
		                        "]", ""
		                    )
		                VAR __Slug2 = SUBSTITUTE( __Slug1, " ", "-" )
		                VAR __Slug3 =
		                    SUBSTITUTE(
		                        SUBSTITUTE(
		                            SUBSTITUTE(
		                                SUBSTITUTE( __Slug2, "--", "-" ),
		                                "--", "-"
		                            ),
		                            "--", "-"
		                        ),
		                        "--", "-"
		                    )
		                VAR __Slug = __Slug3
		                RETURN "<h" & __Lvl & " id=""" & __Slug & """>" & __Content & "</h" & __Lvl & ">" & LF,
		                BLANK()
		            )

		        VAR __CodeFence =
		            IF(
		                [IsFenceStart],
		                "<pre><code>" & LF,
		                IF( [IsFenceEnd], "</code></pre>" & LF, BLANK() )
		            )

		        VAR __CodeLine =
		            IF(
		                [InCodeBefore] && NOT [IsFence],
		                __Esc0 & LF,
		                BLANK()
		            )

		        VAR __ParaLine =
		            IF(
		                NOT [InCodeBefore]
		                    && NOT [IsFence]
		                    && NOT [IsBlank]
		                    && NOT [IsUL]
		                    && [HeadingLevel] = 0,
		                __OpenP & __RenderedInline & __CloseP,
		                BLANK()
		            )

		        RETURN
		            COALESCE( __OpenUL, "" )
		                & COALESCE( __CodeFence, "" )
		                & COALESCE( __CodeLine, "" )
		                & COALESCE( __Heading, "" )
		                & COALESCE( __Li, "" )
		                & COALESCE( __ParaLine, "" )
		                & COALESCE( __CloseUL, "" ),
		        "",
		        [Value],
		        ASC
		    )

		RETURN __Html
```

	annotation DAXLIB_PackageId = Fi.Convert

	annotation DAXLIB_PackageVersion = 0.1.0
